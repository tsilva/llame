{
  "project_name": "llame",
  "project_type": "nodejs",
  "bundle": "core-brand",
  "targets": [
    "web-seo"
  ],
  "sources": [
    "built_in_defaults",
    "cli_args"
  ],
  "metadata": {
    "title": "llame: Private In-Browser AI with Next.js & Transformers.js",
    "short_description": "A serverless Next.js web app for running private LLMs directly in the browser using WebGPU and WASM via Transformers.js.",
    "social_title": "llame - Run Private AI Models in Your Browser (No Server Needed)",
    "social_description": "Experience local, private AI inference with llame. Use WebGPU acceleration and Transformers.js to run ONNX models directly on your device with no backend infrastructure.",
    "keywords": [
      "nextjs",
      "transformers-js",
      "webgpu",
      "webassembly",
      "browser-ai",
      "local-llm",
      "onnx-runtime",
      "client-side-inference",
      "private-ai",
      "web-worker"
    ]
  },
